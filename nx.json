{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "extends": "nx/presets/npm.json",
  "nxCloudId": "62a6df5ddbaff92c46e3b366",
  "defaultBase": "main",
  "release": {
    "projectsRelationship": "fixed",
    "projects": ["*"],
    "version": {
      "conventionalCommits": true,
      "updateDependents": "always",
      "git": {
        "commit": true,
        "commitMessage": "chore(release): published new version",
        "push": true,
        "tag": true,
        "stageChanges": true
      }
    },
    "changelog": {
      "workspaceChangelog": true,
      "projectChangelogs": false,
      "git": {
        "commit": true,
        "push": true,
        "stageChanges": true
      }
    }
  },
  "targetDefaults": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "{projectRoot}/dist"
      ],
      "inputs": [
        "production",
        "^production"
      ],
      "cache": true,
      "configurations": {
        "ci": {
          "args": ["--ci"]
        }
      }
    },
    "build:ci": {
      "dependsOn": [
        "^build:ci"
      ],
      "outputs": [
        "{projectRoot}/dist"
      ],
      "cache": true
    }
  },
  "plugins": [
    {
      "plugin": "nx/plugins/package-json",
      "include": [
        "cli/packages/*/package.json",
        "cli/commands/build/package.json"
      ]
    },
    "@tsparticles/cli-nx-plugin"
  ],
  "pluginsConfig": {
    "@nx/js": {
      "analyzeSourceFiles": false
    }
  },
  "namedInputs": {
    "default": [
      "{projectRoot}/**/*",
      "sharedGlobals"
    ],
    "sharedGlobals": [
      "{workspaceRoot}/nx.json",
      "{workspaceRoot}/tsconfig.json",
      "{workspaceRoot}/pnpm-workspace.yaml"
    ],
    "production": [
      "{projectRoot}/src/**/*",
      "{projectRoot}/index.*",
      "{projectRoot}/package.json",
      "{projectRoot}/tsconfig*.json",
      "sharedGlobals"
    ]
  },
  "analytics": true
}
