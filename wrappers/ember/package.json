{
  "name": "@tsparticles/ember",
  "version": "4.0.0-beta.16",
  "description": "Ember.js component for using tsParticles",
  "keywords": [
    "ember-addon"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tsparticles/tsparticles.git",
    "directory": "wrappers/ember"
  },
  "license": "MIT",
  "author": "Ignace Maes (https://ignacemaes.com/)",
  "directories": {
    "doc": "doc",
    "test": "tests"
  },
  "scripts": {
    "build": "ember build",
    "lint": "npm-run-all --print-name --aggregate-output --continue-on-error --parallel \"lint:!(fix)\"",
    "lint:fix": "npm-run-all --print-name --aggregate-output --continue-on-error --parallel \"lint:*:fix\"",
    "lint:hbs": "ember-template-lint .",
    "lint:hbs:fix": "ember-template-lint . --fix",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "start": "ember serve",
    "test": "npm-run-all --print-name \"lint\" \"test:*\"",
    "test:ember": "echo test",
    "test:ember-compatibility": "echo ember try:each",
    "prepack": "ember ts:precompile",
    "postpack": "ember ts:clean"
  },
  "dependencies": {
    "@tsparticles/engine": "workspace:^",
    "ember-auto-import": "^2.13.1",
    "ember-cli-babel": "^8.3.1",
    "ember-cli-htmlbars": "^7.0.1",
    "ember-cli-typescript": "^5.3.0",
    "ember-modifier": "^4.3.0",
    "ember-test-selectors": "^7.1.0"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@ember/optional-features": "^3.0.0",
    "@ember/test-helpers": "^5.4.1",
    "@embroider/test-setup": "^4.0.0",
    "@glimmer/component": "^2.1.1",
    "@glimmer/tracking": "^1.1.2",
    "@tsconfig/ember": "^3.0.12",
    "@tsparticles/preset-snow": "workspace:^",
    "@types/ember": "^4.0.11",
    "@types/ember-qunit": "^6.1.3",
    "@types/ember-resolver": "^9.0.2",
    "@types/ember__application": "^4.0.11",
    "@types/ember__array": "^4.0.10",
    "@types/ember__component": "^4.0.22",
    "@types/ember__controller": "^4.0.12",
    "@types/ember__debug": "^4.0.8",
    "@types/ember__destroyable": "^4.0.5",
    "@types/ember__engine": "^4.0.11",
    "@types/ember__error": "^4.0.6",
    "@types/ember__object": "^4.0.12",
    "@types/ember__polyfills": "^4.0.6",
    "@types/ember__routing": "^4.0.23",
    "@types/ember__runloop": "^4.0.10",
    "@types/ember__service": "^4.0.9",
    "@types/ember__string": "^3.0.15",
    "@types/ember__template": "^4.0.7",
    "@types/ember__test": "^4.0.6",
    "@types/ember__test-helpers": "^2.9.3",
    "@types/ember__utils": "^4.0.7",
    "@types/qunit": "^2.19.13",
    "@types/rsvp": "^4.0.9",
    "@types/sinon": "^21.0.1",
    "babel-eslint": "^10.1.0",
    "broccoli-asset-rev": "^3.0.0",
    "ember-cli": "~6.12.0",
    "ember-cli-dependency-checker": "^3.3.3",
    "ember-cli-inject-live-reload": "^2.1.0",
    "ember-cli-sri": "^2.1.1",
    "ember-cli-terser": "^4.0.2",
    "ember-disable-prototype-extensions": "^1.1.3",
    "ember-load-initializers": "^3.0.1",
    "ember-page-title": "^9.0.3",
    "ember-qunit": "^9.0.4",
    "ember-resolver": "^13.2.0",
    "ember-sinon-qunit": "^7.5.0",
    "ember-source": "~6.12.0",
    "ember-source-channel-url": "^3.0.0",
    "ember-template-lint": "^7.9.3",
    "ember-try": "^4.0.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-ember": "^12.7.5",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-qunit": "^8.2.6",
    "loader.js": "^4.7.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.2",
    "qunit": "^2.25.0",
    "qunit-dom": "^3.5.0",
    "tsparticles": "workspace:^",
    "typescript": "^6.0.2",
    "webpack": "^5.106.1"
  },
  "engines": {
    "node": "14.* || 16.* || >= 18"
  },
  "ember": {
    "edition": "octane"
  },
  "nx": {
    "targets": {
      "build": {
        "inputs": ["production", "^production", "{projectRoot}/addon/**/*", "{projectRoot}/app/**/*", "{projectRoot}/config/**/*", "{projectRoot}/index.js"]
      }
    }
  },
  "ember-addon": {
    "configPath": "tests/dummy/config"
  },
  "publishConfig": {
    "access": "public"
  }
}
