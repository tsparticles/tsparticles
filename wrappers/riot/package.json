{
  "name": "@tsparticles/riot",
  "version": "4.3.2",
  "description": "Official tsParticles Riot Component - Easily create highly customizable particle, confetti and fireworks animations and use them as animated backgrounds for your website. Ready to use components available also for Web Components, React, Vue.js (2.x and 3.x), Angular, Svelte, jQuery, Preact, Inferno.",
  "main": "dist/riot-particles.cjs",
  "module": "dist/riot-particles.esm.js",
  "exports": {
    ".": {
      "import": "./dist/riot-particles.esm.js",
      "require": "./dist/riot-particles.cjs"
    }
  },
  "scripts": {
    "prettify:ci:src": "prettier --check ./src/*",
    "prettify:ci:readme": "prettier --check ./README.md",
    "prettify:src": "prettier --write ./src/*",
    "prettify:readme": "prettier --write ./README.md",
    "build": "pnpm run prettify:src && rollup -c && node ../../scripts/resolve-dist-package.cjs",
    "build:ci": "pnpm run prettify:ci:src && rollup -c && node ../../scripts/resolve-dist-package.cjs",
    "prepack": "pnpm run build",
    "version": "node ../../scripts/resolve-dist-package.cjs && git add package.dist.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tsparticles/tsparticles.git",
    "directory": "wrappers/riot"
  },
  "keywords": [
    "front-end",
    "frontend",
    "tsparticles",
    "particles.js",
    "particlesjs",
    "particles",
    "particle",
    "canvas",
    "jsparticles",
    "xparticles",
    "particles-js",
    "particles-bg",
    "particles-bg-vue",
    "particles-ts",
    "particles.ts",
    "react-particles-js",
    "react-particles.js",
    "react-particles",
    "react",
    "reactjs",
    "vue-particles",
    "ngx-particles",
    "angular-particles",
    "particleground",
    "vue",
    "vuejs",
    "preact",
    "preactjs",
    "jquery",
    "angularjs",
    "angular",
    "typescript",
    "javascript",
    "animation",
    "web",
    "html5",
    "web-design",
    "webdesign",
    "css",
    "html",
    "css3",
    "animated",
    "background",
    "confetti",
    "canvas",
    "fireworks",
    "fireworks-js",
    "confetti-js",
    "confettijs",
    "fireworksjs",
    "canvas-confetti"
  ],
  "author": "Matteo Bruni <matteo.bruni@me.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/tsparticles/tsparticles/issues"
  },
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/matteobruni"
    },
    {
      "type": "github",
      "url": "https://github.com/sponsors/tsparticles"
    },
    {
      "type": "buymeacoffee",
      "url": "https://www.buymeacoffee.com/matteobruni"
    }
  ],
  "prettier": "@tsparticles/prettier-config",
  "peerDependencies": {
    "@tsparticles/engine": "workspace:*",
    "riot": "^10"
  },
  "dependencies": {
    "@tsparticles/engine": "workspace:*"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/preset-typescript": "^8.0.0",
    "@riotjs/cli": "^10.0.0",
    "@riotjs/compiler": "^10.0.2",
    "@rollup/plugin-babel": "^7.1.0",
    "@tsparticles/prettier-config": "workspace:*",
    "chai": "^6.2.2",
    "esm": "^3.2.25",
    "jsdom": "^29.1.1",
    "jsdom-global": "^3.0.2",
    "mocha": "^11.7.6",
    "nyc": "^18.0.0",
    "prettier": "^3.9.4",
    "riot": "^10.1.4",
    "rollup": "^4.62.2",
    "rollup-plugin-riot": "^10.0.0"
  },
  "publishConfig": {
    "access": "public",
    "directory": "dist",
    "linkDirectory": true
  },
  "files": [
    "dist"
  ]
}
