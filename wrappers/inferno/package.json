{
  "name": "@tsparticles/inferno",
  "version": "4.3.3",
  "description": "Official tsParticles Inferno Component - Easily create highly customizable particle, confetti and fireworks animations and use them as animated backgrounds for your website. Ready to use components available also for Web Components, React, Vue.js (2.x and 3.x), Angular, Svelte, jQuery, Preact, Riot.js, Solid.js.",
  "main": "dist/particles.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "pnpm run lint && webpack --mode production && pnpm run build:types && node ../../scripts/resolve-dist-package.cjs",
    "build:ci": "pnpm run lint:ci && webpack --mode production && node ../../scripts/resolve-dist-package.cjs",
    "check": "tsc",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx --fix",
    "lint:ci": "eslint src --ext .js,.jsx,.ts,.tsx",
    "prettify:ci:src": "prettier --check ./src/*",
    "prettify:ci:readme": "prettier --check ./README.md",
    "prettify:src": "prettier --write ./src/*",
    "prettify:readme": "prettier --write ./README.md",
    "prepack": "pnpm run build",
    "build:types": "tsc -p tsconfig.types.json",
    "version": "node ../../scripts/resolve-dist-package.cjs && git add package.dist.json"
  },
  "bugs": {
    "url": "https://github.com/tsparticles/tsparticles/issues"
  },
  "repository": {
    "url": "git+https://github.com/tsparticles/tsparticles.git",
    "directory": "wrappers/inferno",
    "type": "git"
  },
  "keywords": [
    "front-end",
    "frontend",
    "tsparticles",
    "particles.js",
    "particlesjs",
    "particles",
    "particle",
    "canvas",
    "jsparticles",
    "xparticles",
    "particles-js",
    "particles-bg",
    "particles-bg-vue",
    "particles-ts",
    "particles.ts",
    "react-particles-js",
    "react-particles.js",
    "react-particles",
    "react",
    "reactjs",
    "vue-particles",
    "ngx-particles",
    "angular-particles",
    "particleground",
    "vue",
    "vuejs",
    "preact",
    "preactjs",
    "jquery",
    "angularjs",
    "angular",
    "typescript",
    "javascript",
    "animation",
    "web",
    "html5",
    "web-design",
    "webdesign",
    "css",
    "html",
    "css3",
    "animated",
    "background",
    "confetti",
    "canvas",
    "fireworks",
    "fireworks-js",
    "confetti-js",
