    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "babel-loader": "^10.1.1",
    "babel-plugin-inferno": "^6.8.5",
    "clean-webpack-plugin": "^4.0.0",
    "css-loader": "^7.1.4",
