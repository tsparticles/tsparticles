{
  "name": "@tsparticles/astro",
  "version": "4.0.0-beta.16",
  "description": "Official tsParticles Astro Component - Easily create highly customizable particle, confetti and fireworks animations and use them as animated backgrounds for your website. Ready to use components available also for Web Components, Vue.js (2.x and 3.x), Angular, Svelte, jQuery, Preact, React.js, Riot.js, Solid.js, Inferno.",
  "type": "module",
  "scripts": {
    "prettify:ci:src": "prettier --plugin=prettier-plugin-astro --check \"./src/**/*.{js,ts,css,astro,md}\"",
    "prettify:ci:readme": "prettier --check ./README.md",
    "prettify:src": "prettier --plugin=prettier-plugin-astro --write \"./src/**/*.{js,ts,css,astro,md}\"",
    "prettify:readme": "prettier --write ./README.md",
    "build": "pnpm run prettify:src && pnpm run prettify:readme && tsc --noEmit",
    "build:ci": "pnpm run prettify:ci:src && pnpm run prettify:ci:readme && tsc --noEmit",
    "prepack": "pnpm run build"
  },
  "repository": {
    "url": "git+https://github.com/tsparticles/tsparticles.git",
    "directory": "wrappers/astro",
    "type": "git"
  },
  "keywords": [
    "astro",
    "astro-integration",
    "astro-component",
    "front-end",
    "frontend",
    "tsparticles",
    "particles.js",
    "particlesjs",
    "particles",
    "particle",
    "canvas",
    "jsparticles",
    "xparticles",
    "particles-js",
    "particles-bg",
    "particles-bg-vue",
    "particles-ts",
    "particles.ts",
    "@tsparticles/react-js",
    "@tsparticles/react.js",
    "@tsparticles/react",
    "react",
    "reactjs",
    "vue-particles",
    "ngx-particles",
    "angular-particles",
    "particleground",
    "vue",
    "vuejs",
    "preact",
    "preactjs",
    "jquery",
    "angularjs",
    "angular",
    "typescript",
    "javascript",
    "animation",
    "web",
    "html5",
    "web-design",
    "webdesign",
    "css",
    "html",
    "css3",
    "animated",
    "background",
    "confetti",
    "canvas",
    "fireworks",
    "fireworks-js",
    "confetti-js",
    "confettijs",
    "fireworksjs",
    "canvas-confetti"
  ],
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/matteobruni"
    },
    {
      "type": "github",
      "url": "https://github.com/sponsors/tsparticles"
    },
    {
      "type": "buymeacoffee",
      "url": "https://www.buymeacoffee.com/matteobruni"
    }
  ],
  "bugs": {
    "url": "https://github.com/tsparticles/astro/issues"
  },
  "author": "Matteo Bruni <matteo.bruni@me.com>",
  "license": "MIT",
  "prettier": "@tsparticles/prettier-config",
  "exports": {
    ".": {
      "types": "./index.ts",
      "node": "./index.server.js",
      "browser": "./index.client.js",
      "import": "./index.client.js",
      "default": "./index.server.js"
    }
  },
  "main": "./index.server.js",
  "module": "./index.client.js",
  "browser": "./index.client.js",
  "peerDependencies": {
    "astro": "^6.1.6"
  },
  "dependencies": {
    "@tsparticles/engine": "workspace:^"
  },
  "devDependencies": {
    "@tsparticles/prettier-config": "workspace:^",
    "astro": "^6.2.2",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.9.3"
  },
  "nx": {
    "targets": {
      "build": {
        "inputs": ["production", "^production", "{projectRoot}/index.ts"]
      }
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
