---
import type { Container, ISourceOptions } from "@tsparticles/engine";

export interface IParticlesProps {
  id: string;
  loaded?: string;
  options?: ISourceOptions;
  url?: string;
  theme?: string;
}

const { id, loaded, options, url, theme } = Astro.props as IParticlesProps;
---

<astro-particles
  data-id={id}
  data-options={JSON.stringify(options)}
  data-url={url}
  data-loaded={loaded}
  data-theme={theme}
>
  <canvas></canvas>
</astro-particles>

<script>
  import { tsParticles } from "@tsparticles/engine";

  function getGlobalStore() {
    return window;
  }

  class AstroParticles extends HTMLElement {
    #container;
    #loadId = 0;

    static get observedAttributes() {
      return ["data-id", "data-options", "data-url", "data-theme"];
    }

    constructor() {
      super();
    }

    connectedCallback() {
      void this.#loadParticles(++this.#loadId);
    }

    disconnectedCallback() {
      this.#loadId++;
      if (this.#container) {
        this.#container.destroy();
        this.#container = undefined;
      }
    }

    attributeChangedCallback(name, oldValue, newValue) {
      if (oldValue === newValue) return;
      if (!this.isConnected) return;

      if (name === "data-theme") {
        if (this.#container) {
          void this.#container.loadTheme?.(newValue ?? undefined);
        }
        return;
      }

      if (this.#container) {
        this.#container.destroy();
        this.#container = undefined;
      }
      void this.#loadParticles(++this.#loadId);
    }

    async #loadParticles(currentLoadId) {
      const { isParticlesEngineInitialized, waitForParticlesEngineInitialization } = await import("@tsparticles/astro");

      await waitForParticlesEngineInitialization();

      if (!isParticlesEngineInitialized()) {
        for (let i = 0; i < 20 && !isParticlesEngineInitialized(); i++) {
          await new Promise((resolve) => setTimeout(resolve, 0));
          await waitForParticlesEngineInitialization();
        }
      }

      if (!isParticlesEngineInitialized()) {
        throw new Error("initParticlesEngine(...) must be called once before rendering <Particles /> components.");
      }

      if (currentLoadId !== this.#loadId) return;

      const globalStore = getGlobalStore();

      let container;

      if (this.dataset.url) {
        container = await tsParticles.load({
          id: this.dataset.id,
          url: this.dataset.url,
        });
      } else if (this.dataset.options) {
        container = await tsParticles.load({
          id: this.dataset.id,
          options: JSON.parse(this.dataset.options),
        });
      }

      if (currentLoadId !== this.#loadId) {
        if (container) container.destroy();
        return;
      }

      this.#container = container;

      if (container && this.dataset.theme) {
        void container.loadTheme?.(this.dataset.theme);
      }

      if (this.dataset.loaded && this.dataset.loaded in globalStore) {
        const loadedFn = globalStore[this.dataset.loaded];

        if (loadedFn instanceof Function) {
          loadedFn(container);
        }
      }
    }
  }

  customElements.define("astro-particles", AstroParticles);
</script>
