{
  "name": "@tsparticles/nuxt2",
  "version": "4.2.1",
  "description": "Official tsParticles Nuxt 2 Module - Easily create highly customizable particle, confetti and fireworks animations and use them as animated backgrounds for your website.",
  "keywords": [
    "tsparticles",
    "particles",
    "particle",
    "canvas",
    "animation",
    "background",
    "confetti",
    "fireworks",
    "nuxt",
    "nuxt2",
    "nuxt-module",
    "vue",
    "vue2"
  ],
  "bugs": {
    "url": "https://github.com/tsparticles/tsparticles/issues"
  },
  "homepage": "https://particles.js.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tsparticles/tsparticles.git",
    "directory": "wrappers/nuxt2"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "prettier --write README.md && pnpm run prettify && tsc -p tsconfig.json && copyfiles -f lib/plugin.js dist && node ../../scripts/resolve-dist-package.cjs",
    "build:ci": "prettier --check README.md && pnpm run prettify:ci && tsc -p tsconfig.json && copyfiles -f lib/plugin.js dist && node ../../scripts/resolve-dist-package.cjs",
    "lint": "eslint . --max-warnings 0",
    "prettify": "prettier --write \"lib/**/*.ts\"",
    "prettify:ci": "prettier --check \"lib/**/*.ts\"",
    "prepublishOnly": "pnpm run build",
    "version": "node ../../scripts/resolve-dist-package.cjs && git add package.dist.json",
    "prepack": "pnpm run build"
  },
  "license": "MIT",
  "dependencies": {
    "@nuxt/types": "^2.18.1",
    "@tsparticles/engine": "workspace:*",
    "@tsparticles/vue2": "workspace:*"
  },
  "peerDependencies": {
    "@tsparticles/engine": "workspace:*",
    "nuxt": ">=2.0.0 <3.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "typescript": "^6.0.3"
  },
  "nx": {
    "targets": {
      "build": {
        "inputs": [
          "production",
          "^production",
          "{projectRoot}/lib/**/*"
        ]
      }
    }
  },
  "publishConfig": {
    "access": "public",
    "directory": "dist",
    "linkDirectory": true
  }
}
