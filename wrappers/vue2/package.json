{
  "name": "@tsparticles/vue2",
  "version": "4.2.0",
  "main": "dist/vue2-particles.umd.js",
  "module": "dist/vue2-particles.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/vue2-particles.es.js",
      "require": "./dist/vue2-particles.umd.js",
      "default": "./dist/vue2-particles.umd.js"
    }
  },
  "description": "Official tsParticles Vue.js 2.x Component - Easily create highly customizable particle, confetti and fireworks animations and use them as animated backgrounds for your website. Ready to use components available also for Web Components, React, Vue.js 3.x, Angular, Svelte, jQuery, Preact, Riot.js, Solid.js, Inferno.",
  "scripts": {
    "clean": "rm -rf dist/*",
    "dev": "vite",
    "build": "pnpm run clean && pnpm run prettify:src && pnpm run prettify:readme && vite build && node ../../scripts/resolve-dist-package.cjs",
    "build:ci": "pnpm run clean && pnpm run prettify:ci:src && pnpm run prettify:ci:readme && vite build && node ../../scripts/resolve-dist-package.cjs",
    "preview": "vite preview --port 5050",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint . --fix",
    "prettify:ci:src": "prettier --check ./src/*",
    "prettify:ci:readme": "prettier --check ./README.md",
    "prettify:src": "prettier --write ./src/*",
    "prettify:readme": "prettier --write ./README.md",
    "prepack": "pnpm run build",
    "version": "node ../../scripts/resolve-dist-package.cjs && git add package.dist.json"
  },
  "keywords": [
    "front-end",
    "frontend",
    "tsparticles",
    "particles.js",
    "particlesjs",
    "particles",
    "particle",
    "canvas",
    "jsparticles",
    "xparticles",
    "particles-js",
    "particles-bg",
    "particles-bg-vue",
    "particles-ts",
    "particles.ts",
    "react-particles-js",
    "react-particles.js",
    "react-particles",
    "react",
    "reactjs",
    "vue-particles",
    "ngx-particles",
    "angular-particles",
    "particleground",
    "vue",
    "vuejs",
    "preact",
    "preactjs",
    "jquery",
    "angularjs",
    "angular",
    "typescript",
    "javascript",
    "animation",
    "web",
    "html5",
    "web-design",
    "webdesign",
    "css",
    "html",
    "css3",
    "animated",
    "background",
    "confetti",
    "canvas",
    "fireworks",
    "fireworks-js",
    "confetti-js",
    "confettijs",
    "fireworksjs",
    "canvas-confetti"
  ],
  "unpkg": "dist/vue2-particles.umd.js",
  "jsdelivr": "dist/vue2-particles.umd.js",
  "repository": {
    "url": "git+https://github.com/tsparticles/tsparticles.git",
    "type": "git",
    "directory": "wrappers/vue2"
  },
  "author": "Matteo Bruni <matteo.bruni@me.com>",
  "license": "MIT",
  "files": [
    "dist",
    "README.md"
  ],
  "bugs": {
    "url": "https://github.com/tsparticles/tsparticles/issues"
  },
  "homepage": "https://particles.js.org",
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/matteobruni"
    },
    {
      "type": "github",
      "url": "https://github.com/sponsors/tsparticles"
    },
    {
      "type": "buymeacoffee",
      "url": "https://www.buymeacoffee.com/matteobruni"
    }
  ],
  "prettier": "@tsparticles/prettier-config",
  "peerDependencies": {
    "@tsparticles/engine": "workspace:*",
    "vue": "^2.7.0"
  },
  "publishConfig": {
    "access": "public",
    "directory": "dist",
    "linkDirectory": true
  },
  "dependencies": {
    "@tsparticles/engine": "workspace:*"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tsparticles/prettier-config": "workspace:*",
    "@types/node": "^25.9.3",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitejs/plugin-vue2": "^2.3.4",
    "eslint": "^10.5.0",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2",
    "vue": "^2.7.16",
    "vue-class-component": "^7.2.6",
    "vue-eslint-parser": "^10.4.1",
    "vue-property-decorator": "^9.1.2",
    "vue-template-compiler": "^2.7.16",
    "vue-tsc": "^3.3.5"
  }
}
