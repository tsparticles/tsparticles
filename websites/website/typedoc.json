{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": [
    "../../engine",
    "../../bundles/*",
    "../../interactions/*",
    "../../interactions/external/*",
    "../../interactions/particles/*",
    "../../paths/*",
    "../../plugins/*",
    "../../plugins/colors/*",
    "../../plugins/easings/*",
    "../../plugins/emittersShapes/*",
    "../../plugins/exports/*",
    "../../shapes/*",
    "../../updaters/*",
    "../../effects/*",
    "../../presets/*",
    "../../palettes/*/*"
  ],
  "entryPointStrategy": "packages",
  "name": "tsParticles",
  "includeVersion": true,
  "hideGenerator": true,
  "out": "typedoc-dist",
  "hostedBaseUrl": "https://particles.js.org/docs",
  "useHostedBaseUrlForAbsoluteLinks": true,
  "plugin": [
    "typedoc-plugin-google-ads",
    "typedoc-plugin-clarity",
    "typedoc-plugin-coverage",
    "typedoc-plugin-keywords",
    "typedoc-plugin-mdn-links"
  ],
  "searchInComments": true,
  "tsconfig": "../../tsconfig.json",
  "clarityId": "8q4bxin4tm",
  "googleAdsId": "ca-pub-6401284988946422",
  "keywords": [
    "html",
    "css",
    "javascript",
    "typescript",
    "particles",
    "js",
    "ts",
    "jsx",
    "tsx",
    "canvas",
    "confetti",
    "fireworks",
    "animations",
    "react",
    "vue",
    "angular",
    "svelte",
    "libraries",
    "how",
    "to",
    "create",
    "add"
  ],
  "validation": {
    "invalidLink": true,
    "notDocumented": true
  }
}
