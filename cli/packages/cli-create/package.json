  "license": "MIT",
  "type": "module",
  "bin": {
    "tsparticles-create": "bin/tsparticles-create.cjs"
  },
  "publishConfig": {
    "access": "public",
    "tagVersionPrefix": "v"
  },
  "repository": {
    "type": "git",
