  "peerDependencies": {
    "@tsparticles/engine": "workspace:*"
  },
  "devDependencies": {
    "@tsparticles/cli-build": "workspace:^",
    "@tsparticles/engine": "workspace:*",
    "@tsparticles/path-utils": "workspace:*"
  },
  "publishConfig": {
    "access": "public",
    "directory": "dist",
    "linkDirectory": true
  },
