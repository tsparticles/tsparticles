    },
    "./spades/lazy": {
      "types": "./dist/types/spades/index.lazy.d.ts",
      "browser": "./dist/browser/spades/index.lazy.js",
      "import": "./dist/esm/spades/index.lazy.js",
      "require": "./dist/cjs/spades/index.lazy.js",
      "default": "./dist/esm/spades/index.lazy.js"
    },
    "./suits": {
      "types": "./dist/types/suits.d.ts",
      "browser": "./dist/browser/suits.js",
      "import": "./dist/esm/suits.js",
      "require": "./dist/cjs/suits.js",
      "default": "./dist/esm/suits.js"
    },
    "./suits/lazy": {
      "types": "./dist/types/suits.lazy.d.ts",
