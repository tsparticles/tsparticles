{{page-title "tsParticles Ember Demo"}}

<h1 id="title">tsParticles Ember Demo</h1>

<button type="button" {{on "click" this.switchConfig}}>
  Switch config
</button>

<button type="button" {{on "click" this.toggleTheme}}>
  Theme: {{this.theme}}
</button>

<button
  type="button"
  {{on
    "click"
    (fn (mut this.isConfettiVisible) (if this.isConfettiVisible false true))
  }}
>
  {{if this.isConfettiVisible "Hide" "Show"}} confetti
</button>

<Particles
  class="fixed-size-particles"
  @options={{this.options}}
  @theme={{this.theme}}
  @particlesLoaded={{this.loadedCallback}}
/>

<Particles
  class="fixed-size-snow"
  @options={{hash preset="snow" fullScreen=(hash enable=false)}}
/>

{{#if this.isConfettiVisible}}
  <Particles @options={{this.confetti}} />
{{/if}}
