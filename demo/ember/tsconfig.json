{
  "compilerOptions": {
    "target": "es2021",
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "allowSyntheticDefaultImports": true,
    "noPropertyAccessFromIndexSignature": true,
    "noEmitOnError": false,
    "noEmit": true,
    "ignoreDeprecations": "6.0",
    "experimentalDecorators": true,
    "declaration": false,
    "declarationMap": false,
    "inlineSourceMap": false,
    "inlineSources": false,
    "types": [],
    "baseUrl": ".",
    "paths": {
      "ember-demo/*": [
        "app/*"
      ],
      "@tsparticles/ember-demo/*": [
        "app/*"
      ],
      "@tsparticles/ember": [
        "../../wrappers/ember/addon"
      ],
      "@tsparticles/ember/*": [
        "../../wrappers/ember/addon/*"
      ]
    }
  },
  "include": [
    "app/**/*",
    "config/**/*"
  ]
}
